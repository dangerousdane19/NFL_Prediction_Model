# SportsData.io API key (required)
# Get yours at https://sportsdata.io
SPORTSDATA_API_KEY=your_key_here

# Database path (SQLite for local dev; use DATABASE_URL for Streamlit Cloud)
DB_PATH=data/nfl_predictions.db

# For Streamlit Cloud with Supabase PostgreSQL:
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# Directory where trained .joblib model files are saved
MODEL_DIR=models

# Google Trends (optional — set to true only if you want to try it locally)
# Frequently rate-limited; predictions default trend features to 0 when disabled
GOOGLE_TRENDS_ENABLED=false
